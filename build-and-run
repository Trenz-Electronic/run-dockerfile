#
# build-and-run - Docker Container Manager with Auto-build
#
# A generalized script for running Docker containers with automatic rebuilding
# when images don't exist. Handles cross-platform builds, user mapping, and
# volume mounting for seamless development workflows.
#
# FEATURES:
# - Automatic Docker image building when missing
# - Cross-platform support via Dockerfile platform directives
# - User/group mapping to avoid permission issues
# - Automatic volume mounting based on working directory location
# - TTY detection for interactive sessions
#
# SETUP:
# 1. Create a container directory in your project (not inside this submodule):
#    mkdir -p containers/my-container
#
# 2. Add a Dockerfile to that directory:
#    echo 'FROM ubuntu:22.04' > containers/my-container/Dockerfile
#
# 3. Symlink this script as "run" next to the Dockerfile. The symlink target is
#    deliberately NOT followed when locating the container directory, so "run"
#    must live beside the Dockerfile it builds:
#    (cd containers/my-container && ln -s ../../run-dockerfile/build-and-run run)
#
# 4. (Optional) Add a platform directive to the Dockerfile for cross-platform builds:
#    # platform: arm64
#    FROM ubuntu:22.04
#
# USAGE EXAMPLES:
#   ./containers/my-container/run bash               # Start interactive bash
#   ./containers/my-container/run make               # Run make command
#   ./containers/my-container/run python3 script.py  # Run Python script
#
# PLATFORM SUPPORT:
# Add a platform comment in the first 20 lines of your Dockerfile:
#   # platform: arm64     # For ARM64/aarch64
#   # platform: amd64     # For x86_64
#
# If no platform directive is found, Docker uses the host platform.
#
# VOLUME MOUNTING (see the #mount: directive and README.md for details):
# - Default: mount the git repository root if found, otherwise the current dir.
# - #mount: selects explicitly with the .git / pwd / home keywords (first match).
# - $HOME is NOT mounted unless requested (#mount: home, or #copy.home: for
#   individual files).
#
# TECHNICAL NOTES:
# - Creates a temporary user inside the container matching the host UID/GID
# - Drops privileges with su (no sudo required); #sudo: all adds passwordless sudo
# - Preserves the working directory inside the container
# - Auto-detects TTY for interactive sessions
#
# See README.md for the full directive reference and CLAUDE.md for design notes.

set -e

# Verbose mode: set RUN_DOCKERFILE_VERBOSE=1 in environment to enable
RUN_DOCKERFILE_VERBOSE=${RUN_DOCKERFILE_VERBOSE:-0}

# Print informational message only in verbose mode
info() {
  # Compare as a string: RUN_DOCKERFILE_VERBOSE is a flag, and a non-numeric
  # value (e.g. "true") must not make `[ ... -eq 1 ]` emit a shell error.
  if [ "$RUN_DOCKERFILE_VERBOSE" = 1 ]; then
    >&2 echo "$@"
  fi
}

# Literal find/replace, no regex/glob/eval. Args: needle replacement subject.
# Every byte is treated literally, so replacement values containing shell or
# regex metacharacters are safe. Prints the result with no trailing newline.
str_replace() {
  _sr_needle=$1
  _sr_repl=$2
  _sr_rest=$3
  _sr_out=""
  while case $_sr_rest in *"$_sr_needle"*) true ;; *) false ;; esac; do
    _sr_out=$_sr_out${_sr_rest%%"$_sr_needle"*}$_sr_repl
    _sr_rest=${_sr_rest#*"$_sr_needle"}
  done
  printf '%s' "$_sr_out$_sr_rest"
}

# Expand environment-variable references in a #usermount: path, treating the
# directive value as data rather than host-side shell code. Only well-formed
# variable references ($NAME and ${NAME}) are substituted, using their value
# from the environment via printenv; command substitution ($(...) / backticks),
# arithmetic, positional parameters, and any other shell syntax are left
# literal because they cannot match the variable-name pattern. This is the
# safe replacement for the historical `eval echo "$path"`.
expand_usermount_path() {
  _eu_p=$1
  # Distinct references, longest first, so e.g. $HOMEPAGE is resolved before
  # $HOME and a shared prefix never corrupts the longer name.
  _eu_tokens=$(printf '%s\n' "$_eu_p" \
    | grep -oE '\$\{[A-Za-z_][A-Za-z0-9_]*\}|\$[A-Za-z_][A-Za-z0-9_]*' \
    | awk '!seen[$0]++ { print length, $0 }' | sort -rn | cut -d' ' -f2-)
  for _eu_tok in $_eu_tokens; do
    # Strip the leading $ and optional braces to get the bare variable name.
    _eu_name=${_eu_tok#'$'}
    _eu_name=${_eu_name#'{'}
    _eu_name=${_eu_name%'}'}
    _eu_val=$(printenv "$_eu_name" 2>/dev/null || true)
    _eu_p=$(str_replace "$_eu_tok" "$_eu_val" "$_eu_p")
  done
  printf '%s' "$_eu_p"
}

print_usage() {
  cat <<'EOF'
Usage: ./run [run-dockerfile options] COMMAND [ARGS...]

Supported command-line options:
  -e, --env VAR=VALUE         pass an environment variable
  -v, --volume SPEC           add a Docker volume mount
  -p, --publish SPEC          publish a container port
  -w, --workdir PATH          set the container working directory
  --network, --net NAME       set the Docker network
  --device PATH               pass a host device
  --cpus VALUE                limit CPUs
  -m, --memory VALUE          limit memory
  --gpus VALUE                request GPUs
  --name NAME                 set the container name
  --privileged                run with extended privileges
  --read-only                 make the container filesystem read-only

Examples:
  ./run /bin/sh
  ./run make test
  ./run -e DEBUG=1 env
  ./run -v "$PWD/cache:/cache" sh

Dockerfile directives, to be used in the first 20 lines of Dockerfile:
  #option:        add Docker run options
  #mount:         choose mounted host directory: .git, pwd, or home
  #copy.home:     copy one host home file or directory into container home
  #usermount:     mount one host path into the same in-container path
  #platform:      set build platform: arm64, amd64, armv7, ...
  #http.static:   serve a host directory during image build
  #context:       choose Docker build context
  #sudo:          enable passwordless sudo with "#sudo: all"

Note:
  The #option: directive accepts any Docker run option, not just the limited subset listed above.
EOF
}

case "${1:-}" in
  --help|-h)
    print_usage
    exit 0
    ;;
esac

host_realpath_no_symlinks() {
  _hrns_path=$1
  case $_hrns_path in
    /*) ;;
    *) _hrns_path=$PWD/$_hrns_path ;;
  esac

  _hrns_prefix=""
  case $_hrns_path in
    /*)
      _hrns_prefix="/"
      _hrns_path=${_hrns_path#/}
      ;;
  esac

  _hrns_parts=()
  _hrns_rest=$_hrns_path
  while [ -n "$_hrns_rest" ]; do
    _hrns_part=${_hrns_rest%%/*}
    if [ "$_hrns_part" = "$_hrns_rest" ]; then
      _hrns_rest=""
    else
      _hrns_rest=${_hrns_rest#*/}
    fi

    case $_hrns_part in
      ""|.) ;;
      ..)
        if [ ${#_hrns_parts[@]} -gt 0 ]; then
          unset "_hrns_parts[${#_hrns_parts[@]}-1]"
        elif [ -z "$_hrns_prefix" ]; then
          _hrns_parts+=("..")
        fi
        ;;
      *) _hrns_parts+=("$_hrns_part") ;;
    esac
  done

  _hrns_out=$_hrns_prefix
  _hrns_sep=""
  for _hrns_part in "${_hrns_parts[@]}"; do
    _hrns_out=$_hrns_out$_hrns_sep$_hrns_part
    _hrns_sep="/"
  done
  printf '%s\n' "${_hrns_out:-.}"
}

trim_space() {
  printf '%s' "$1" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//'
}

is_passthrough_build_context_value() {
  _ipbcv_value=$1
  case "$_ipbcv_value" in
    "") return 0 ;;
    *://*) return 0 ;;
    target:*) return 0 ;;
  esac
  [[ "$_ipbcv_value" =~ ^[^[:space:]@]+@[^[:space:]:]+:.+ ]]
}

resolve_build_context_value() {
  _rbcv_value=$1
  if is_passthrough_build_context_value "$_rbcv_value"; then
    printf '%s\n' "$_rbcv_value"
    return 0
  fi

  case "$_rbcv_value" in
    /*) host_realpath_no_symlinks "$_rbcv_value" ;;
    *)  host_realpath_no_symlinks "$dir/$_rbcv_value" ;;
  esac
}

build_context_value_is_local() {
  _bcvil_value=$1
  [ -n "$_bcvil_value" ] || return 1
  ! is_passthrough_build_context_value "$_bcvil_value"
}

host_sha256() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum | cut -d' ' -f1
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | cut -d' ' -f1
  elif command -v openssl >/dev/null 2>&1; then
    openssl dgst -sha256 -r | cut -d' ' -f1
  else
    >&2 echo "ERROR: Need one of sha256sum, shasum, or openssl for SHA-256 hashing"
    return 1
  fi
}

host_tar() {
  if command -v gtar >/dev/null 2>&1; then
    printf '%s\n' gtar
  else
    printf '%s\n' tar
  fi
}

real_self=$(host_realpath_no_symlinks "$0")
dir=$(dirname "${real_self}")
tag=$(basename "$dir")

# The image tag is the container directory name, so it must be a valid Docker
# image reference. Fail early with an actionable message instead of letting
# `docker build` emit a cryptic "repository name must be lowercase" error.
if [[ ! "$tag" =~ ^[a-z0-9][a-z0-9._-]*$ ]]; then
  >&2 echo "ERROR: container directory name '${tag}' is not a valid Docker image name."
  >&2 echo "       Docker image names must be lowercase and match [a-z0-9][a-z0-9._-]*."
  >&2 echo "       Rename the directory (e.g. all-lowercase, no spaces) and try again."
  exit 1
fi

# Parse command-line options meant for docker.
# Args are accumulated into bash arrays (not strings) so values containing
# spaces or glob characters are passed to docker verbatim. CMDLINE_ENV_VARS
# stays a comma-separated string because it is data (a list of variable names).
CMDLINE_ENV_ARGS=()
CMDLINE_ENV_VARS=""
CMDLINE_DOCKER_ARGS=()
require_option_value() {
  _rov_opt=$1
  _rov_count=$2
  if [ "$_rov_count" -lt 2 ]; then
    >&2 echo "ERROR: option '${_rov_opt}' requires a value"
    exit 1
  fi
}
while [ $# -gt 0 ]; do
  case "$1" in
    -e)
      # -e VAR=val
      require_option_value "$1" "$#"
      shift
      CMDLINE_ENV_ARGS+=(-e "$1")
      CMDLINE_ENV_VARS="$CMDLINE_ENV_VARS,$(echo "$1" | cut -d= -f1)"
      shift
      ;;
    --env=*)
      # --env=VAR=val
      val="${1#--env=}"
      CMDLINE_ENV_ARGS+=(-e "$val")
      CMDLINE_ENV_VARS="$CMDLINE_ENV_VARS,$(echo "$val" | cut -d= -f1)"
      shift
      ;;
    --env)
      # --env VAR=val
      require_option_value "$1" "$#"
      shift
      CMDLINE_ENV_ARGS+=(-e "$1")
      CMDLINE_ENV_VARS="$CMDLINE_ENV_VARS,$(echo "$1" | cut -d= -f1)"
      shift
      ;;
    -v|--volume)
      # -v /host:/container or --volume /host:/container
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(-v "$1")
      shift
      ;;
    --volume=*)
      # --volume=/host:/container
      val="${1#--volume=}"
      CMDLINE_DOCKER_ARGS+=(-v "$val")
      shift
      ;;
    -p|--publish)
      # -p 8080:80 or --publish 8080:80
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(-p "$1")
      shift
      ;;
    --publish=*)
      # --publish=8080:80
      val="${1#--publish=}"
      CMDLINE_DOCKER_ARGS+=(-p "$val")
      shift
      ;;
    -w|--workdir)
      # -w /path or --workdir /path
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(-w "$1")
      shift
      ;;
    --workdir=*)
      # --workdir=/path
      val="${1#--workdir=}"
      CMDLINE_DOCKER_ARGS+=(-w "$val")
      shift
      ;;
    --network|--net)
      # --network host or --net host
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(--network "$1")
      shift
      ;;
    --network=*|--net=*)
      # --network=host
      val="${1#--network=}"
      val="${val#--net=}"
      CMDLINE_DOCKER_ARGS+=(--network "$val")
      shift
      ;;
    --device)
      # --device /dev/ttyUSB0
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(--device "$1")
      shift
      ;;
    --device=*)
      # --device=/dev/ttyUSB0
      val="${1#--device=}"
      CMDLINE_DOCKER_ARGS+=(--device "$val")
      shift
      ;;
    --cpus)
      # --cpus 2
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(--cpus "$1")
      shift
      ;;
    --cpus=*)
      # --cpus=2
      val="${1#--cpus=}"
      CMDLINE_DOCKER_ARGS+=(--cpus "$val")
      shift
      ;;
    -m|--memory)
      # -m 1g or --memory 1g
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(--memory "$1")
      shift
      ;;
    --memory=*)
      # --memory=1g
      val="${1#--memory=}"
      CMDLINE_DOCKER_ARGS+=(--memory "$val")
      shift
      ;;
    --gpus)
      # --gpus all
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(--gpus "$1")
      shift
      ;;
    --gpus=*)
      # --gpus=all
      val="${1#--gpus=}"
      CMDLINE_DOCKER_ARGS+=(--gpus "$val")
      shift
      ;;
    --name)
      # --name mycontainer
      require_option_value "$1" "$#"
      shift
      CMDLINE_DOCKER_ARGS+=(--name "$1")
      shift
      ;;
    --name=*)
      # --name=mycontainer
      val="${1#--name=}"
      CMDLINE_DOCKER_ARGS+=(--name "$val")
      shift
      ;;
    --privileged|--read-only)
      # Supported boolean flags
      CMDLINE_DOCKER_ARGS+=("$1")
      shift
      ;;
    -*)
      # Unknown option - stop parsing, assume it's part of the command
      break
      ;;
    *)
      # Not an option - this is the command
      break
      ;;
  esac
done
# Remove leading comma from CMDLINE_ENV_VARS
CMDLINE_ENV_VARS=$(echo "$CMDLINE_ENV_VARS" | sed 's/^,//')

# (The "no command specified" check runs later, after engine resolution, so the
# RUN_DOCKERFILE_PRINT_ENGINE diagnostic can report the engine without a command.
# The command in "$@" is untouched until the container run is assembled.)

# Build the normalized directive stream that every directive parser below
# consumes. Two accepted spellings collapse to one canonical "#<keyword>: <value>"
# line here, so the individual parsers never need to learn about the prefix:
#   * New form  - "#run-dockerfile: <keyword> <value>" with '#' at column 1,
#     allowed ANYWHERE in the file. The keyword carries no colon and >=1 space or
#     tab must follow the prefix colon. A missing/empty keyword, missing
#     whitespace, or unknown keyword is a hard error (the prefix signals intent,
#     so a malformed line is reported rather than silently ignored).
#   * Old form  - "#<keyword>: <value>" within the first 20 lines (the historical,
#     now-deprecated spelling). Emitted verbatim and reported as deprecated.
# Lines are emitted in Dockerfile order, so head -1 (#platform:) and tail -1
# (#sudo:) keep their meaning. Errors and the one-time deprecation warning go to
# stderr; only canonical directive lines reach stdout.
build_directive_stream() {
  awk '
    BEGIN {
      split("platform mount copy.home usermount http.static context option sudo rootless", _k, " ")
      for (_i in _k) known[_k[_i]] = 1
      plen = length("#run-dockerfile:")
      err = 0
      ndep = 0
    }
    /^#run-dockerfile:/ {
      rest = substr($0, plen + 1)
      if (rest != "" && rest !~ /^[[:space:]]/) {
        printf("ERROR: #run-dockerfile: directive on line %d needs whitespace after the colon, e.g. #run-dockerfile: option --network host\n", NR) > "/dev/stderr"
        err = 1; next
      }
      sub(/^[[:space:]]+/, "", rest)
      if (rest == "") {
        printf("ERROR: empty #run-dockerfile: directive on line %d; expected a keyword, e.g. #run-dockerfile: option --network host\n", NR) > "/dev/stderr"
        err = 1; next
      }
      kw = rest; sub(/[[:space:]].*/, "", kw)
      val = rest; sub(/^[^[:space:]]+/, "", val); sub(/^[[:space:]]+/, "", val)
      if (!(kw in known)) {
        bare = kw; sub(/:$/, "", bare)
        if (bare in known)
          printf("ERROR: #run-dockerfile: directive on line %d: write the keyword without a colon, e.g. #run-dockerfile: %s ...\n", NR, bare) > "/dev/stderr"
        else
          printf("ERROR: unknown #run-dockerfile: directive keyword %s on line %d\n", kw, NR) > "/dev/stderr"
        err = 1; next
      }
      print "#" kw ": " val
      next
    }
    NR <= 20 && /^#[[:space:]]*(platform|mount|copy\.home|usermount|context|http\.static|option|sudo):/ {
      print $0
      okw = $0; sub(/^#[[:space:]]*/, "", okw); sub(/:.*/, "", okw)
      oval = $0; sub(/^#[[:space:]]*[^:]+:[[:space:]]*/, "", oval)
      ndep++
      dep_line[ndep] = NR
      dep_kw[ndep] = okw
      dep_val[ndep] = oval
      dep_orig[ndep] = $0
      next
    }
    END {
      if (err) exit 1
      if (ndep > 0) {
        print "WARNING: deprecated run-dockerfile directives (the unprefixed form will be removed in a future release; switch to the #run-dockerfile: prefix):" > "/dev/stderr"
        for (i = 1; i <= ndep; i++)
          printf("  line %d: %s  ->  #run-dockerfile: %s %s\n", dep_line[i], dep_orig[i], dep_kw[i], dep_val[i]) > "/dev/stderr"
      }
    }
  ' "$1"
}

# Validate that known run-dockerfile directives are not hidden below the parse
# window. Silently ignoring a late unprefixed directive would make the Dockerfile
# misleading. (Prefixed "#run-dockerfile:" directives are allowed anywhere and are
# not matched here; malformed ones are caught by build_directive_stream below.)
if [ -f "$dir/Dockerfile" ]; then
  MISPLACED_DIRECTIVE=$(awk '
    NR > 20 && /^[[:space:]]*#[[:space:]]*(platform|mount|copy\.home|usermount|context|http\.static|option|sudo):[[:space:]]*/ {
      directive = $0
      sub(/^[[:space:]]*#[[:space:]]*/, "", directive)
      sub(/:.*/, "", directive)
      print NR ":#" directive ":"
      exit
    }
  ' "$dir/Dockerfile")
  if [ -n "$MISPLACED_DIRECTIVE" ]; then
    directive_line=${MISPLACED_DIRECTIVE%%:*}
    directive_name=${MISPLACED_DIRECTIVE#*:}
    >&2 echo "ERROR: run-dockerfile directive '${directive_name}' found on line ${directive_line}; the unprefixed form must appear in the first 20 lines of Dockerfile - move it up, or use the '#run-dockerfile: <directive>' prefix to place it anywhere"
    exit 1
  fi
fi

# Normalize directive spellings (prefixed-anywhere + deprecated unprefixed) into a
# single canonical stream that every parser below consumes instead of re-reading
# the Dockerfile. A malformed prefixed directive exits non-zero here (message
# already on stderr, tripping `set -e`); the deprecation warning, if any, prints
# here too.
DIRECTIVE_STREAM=""
if [ -f "$dir/Dockerfile" ]; then
  DIRECTIVE_STREAM=$(build_directive_stream "$dir/Dockerfile")
fi

# Parse #mount:, #copy.home:, and #usermount: directives from Dockerfile
MOUNT_KEYWORDS=""
COPY_HOME_FILES=()
USERMOUNT_PATHS=()
if [ -f "$dir/Dockerfile" ]; then
  # Parse #mount: directives (first 20 lines, multiple directives allowed)
  MOUNT_LINES=$(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*mount:[[:space:]]*' || true)
  if [ -n "$MOUNT_LINES" ]; then
    MOUNT_KEYWORDS=$(echo "$MOUNT_LINES" | sed -E 's/^#[[:space:]]*mount:[[:space:]]*//' | tr '\n' ' ')
  fi

  # Parse #copy.home: directives (first 20 lines, multiple directives allowed).
  # Each line is exactly ONE path (the whole value after the colon, trimmed), so
  # filenames may contain spaces; use multiple #copy.home: lines for multiple files.
  while IFS= read -r _ch_line; do
    _ch_file=$(printf '%s' "$_ch_line" | sed -E 's/^#[[:space:]]*copy\.home:[[:space:]]*//; s/[[:space:]]+$//')
    [ -n "$_ch_file" ] && COPY_HOME_FILES+=("$_ch_file")
  done < <(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*copy\.home:[[:space:]]*' || true)

  # Parse #usermount: directives (first 20 lines, multiple directives allowed).
  # Each line specifies exactly ONE path (the whole value after the colon,
  # trimmed), so paths may contain spaces. Use multiple #usermount: lines for
  # multiple paths.
  while IFS= read -r _um_line; do
    _um_path=$(printf '%s' "$_um_line" | sed -E 's/^#[[:space:]]*usermount:[[:space:]]*//; s/[[:space:]]+$//')
    [ -n "$_um_path" ] && USERMOUNT_PATHS+=("$_um_path")
  done < <(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*usermount:[[:space:]]*' || true)
fi

# Parse the rootless directive: "#run-dockerfile: rootless --userns=<mode>".
# This directive is prefix-only (it has no deprecated unprefixed spelling), its
# value is mandatory and must be a --userns=<mode> token, and it is passed
# verbatim to the rootless `podman run`. Presence forces rootless Podman (see
# resolve_engine). Multiple directives must agree on a single mode.
ROOTLESS_USERNS=""
while IFS= read -r _rl_line; do
  _rl_val=$(printf '%s' "$_rl_line" | sed -E 's/^#[[:space:]]*rootless:[[:space:]]*//; s/[[:space:]]+$//')
  if [[ ! "$_rl_val" =~ ^--userns=[A-Za-z0-9:=,._-]+$ ]]; then
    >&2 echo "ERROR: #run-dockerfile: rootless requires a --userns=<mode> value, e.g. #run-dockerfile: rootless --userns=keep-id"
    exit 1
  fi
  if [ -n "$ROOTLESS_USERNS" ] && [ "$ROOTLESS_USERNS" != "$_rl_val" ]; then
    >&2 echo "ERROR: conflicting #run-dockerfile: rootless directives ('${ROOTLESS_USERNS}' vs '${_rl_val}'); use a single --userns=<mode>."
    exit 1
  fi
  ROOTLESS_USERNS="$_rl_val"
done < <(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*rootless:[[:space:]]*' || true)

# Global rootless override: RUN_DOCKERFILE_USERNS forces rootless Podman with the
# given --userns=<mode> across the whole run, without editing any Dockerfile - so a
# CI cell (or a user) can exercise the entire suite rootless with correct bind-mount
# ownership. A per-Dockerfile `#run-dockerfile: rootless` directive is more specific
# and takes precedence; this env var is only a global default. Unset => unchanged.
# It only seeds ROOTLESS_USERNS; resolve_engine then forces bare podman and validates
# any RUN_DOCKERFILE_ENGINE selects podman, and ROOTLESS_RUN_ARGS injects the args.
if [ -z "$ROOTLESS_USERNS" ] && [ -n "${RUN_DOCKERFILE_USERNS:-}" ]; then
  _env_userns="--userns=${RUN_DOCKERFILE_USERNS}"
  if [[ ! "$_env_userns" =~ ^--userns=[A-Za-z0-9:=,._-]+$ ]]; then
    >&2 echo "ERROR: RUN_DOCKERFILE_USERNS='${RUN_DOCKERFILE_USERNS}' is not a valid userns mode (e.g. keep-id)."
    exit 1
  fi
  ROOTLESS_USERNS="$_env_userns"
fi

# Resolve the container engine into the ENGINE array (always expanded as
# "${ENGINE[@]}", so a multi-word engine such as "sudo podman" is passed
# verbatim) plus ENGINE_KIND (docker|podman). An explicit RUN_DOCKERFILE_ENGINE
# wins and is taken verbatim; otherwise auto-detect - both engines present
# defaults to Podman, exactly one present uses it, neither present is a hard
# error. Rootful Podman has no root daemon/group like Docker, so it is invoked
# as "sudo podman": this script itself always runs as the real host user (so
# id -un/-u/-g keep detecting the correct identity), and only the engine
# invocations are elevated.
ENGINE=()
ENGINE_KIND=""
resolve_engine() {
  if [ -n "$ROOTLESS_USERNS" ]; then
    # The rootless directive forces rootless Podman: bare "podman" (no sudo).
    if ! command -v podman >/dev/null 2>&1; then
      >&2 echo "ERROR: #run-dockerfile: rootless requires podman, which was not found in PATH."
      exit 1
    fi
    if [ -n "${RUN_DOCKERFILE_ENGINE:-}" ]; then
      read -r -a _re_override <<< "$RUN_DOCKERFILE_ENGINE"
      _re_bin=""
      for _re_w in "${_re_override[@]}"; do
        case "$_re_w" in sudo|-*) continue ;; *) _re_bin="$_re_w"; break ;; esac
      done
      if [ "$(basename "${_re_bin:-}")" != podman ]; then
        >&2 echo "ERROR: #run-dockerfile: rootless requires podman, but RUN_DOCKERFILE_ENGINE='${RUN_DOCKERFILE_ENGINE}' selects a different engine."
        exit 1
      fi
    fi
    ENGINE=(podman); ENGINE_KIND=podman
    return
  fi
  if [ -n "${RUN_DOCKERFILE_ENGINE:-}" ]; then
    read -r -a ENGINE <<< "$RUN_DOCKERFILE_ENGINE"
    _re_bin=""
    for _re_w in "${ENGINE[@]}"; do
      case "$_re_w" in sudo|-*) continue ;; *) _re_bin="$_re_w"; break ;; esac
    done
    if [ -z "$_re_bin" ] || ! command -v "$_re_bin" >/dev/null 2>&1; then
      >&2 echo "ERROR: RUN_DOCKERFILE_ENGINE='${RUN_DOCKERFILE_ENGINE}': command '${_re_bin}' not found in PATH."
      exit 1
    fi
    case "$(basename "$_re_bin")" in
      podman) ENGINE_KIND=podman ;;
      *)      ENGINE_KIND=docker ;;
    esac
    return
  fi
  if command -v podman >/dev/null 2>&1; then
    ENGINE=(sudo podman); ENGINE_KIND=podman
  elif command -v docker >/dev/null 2>&1; then
    ENGINE=(docker); ENGINE_KIND=docker
  else
    >&2 echo "ERROR: no container engine found; install Docker or Podman, or set RUN_DOCKERFILE_ENGINE."
    exit 1
  fi
}
resolve_engine

# Podman's `build` has no --progress flag (it streams build output by default);
# only Docker/BuildKit accepts --progress=plain. Gate it on the engine kind.
PROGRESS_ARGS=()
if [ "$ENGINE_KIND" = docker ]; then
  PROGRESS_ARGS=(--progress=plain)
fi

# Rootless Podman run arguments: the --userns=<mode> from the rootless directive
# (passed verbatim) plus an explicit --user 0. With --userns=keep-id Podman would
# otherwise default the container to the host UID (non-root), but the entry script
# must start as (namespaced) root to create the host-matching user and drop
# privileges with su. Under keep-id, container root maps to a subuid while the host
# UID maps 1:1, so the su'd user's bind-mount writes land owned by the host user.
# (Verified in CI; the rootless path cannot run in the local LXC sandbox.)
ROOTLESS_RUN_ARGS=()
if [ -n "$ROOTLESS_USERNS" ]; then
  ROOTLESS_RUN_ARGS=("$ROOTLESS_USERNS" --user 0)
fi

# RUN_DOCKERFILE_PRINT_ENGINE=1 is a diagnostic: print the resolved engine and
# exit before any build/run, so you can confirm which engine run-dockerfile will
# use here. Only the literal value 1 enables it.
if [ "${RUN_DOCKERFILE_PRINT_ENGINE:-}" = 1 ]; then
  printf '%s\n' "${ENGINE[*]}"
  [ -n "$ROOTLESS_USERNS" ] && printf 'userns: %s\n' "$ROOTLESS_USERNS"
  exit 0
fi

if [ $# -eq 0 ]; then
  >&2 echo "ERROR: no command specified; no container action was taken."
  >&2 echo "       Pass a command, for example './run /bin/sh' or './run /bin/bash'."
  >&2 echo "       Run './run --help' for usage."
  exit 1
fi

# Function to find the git repository root by traversing up from a directory.
# `.git` is a directory in a normal checkout and a regular file (gitlink) in a
# worktree, so test with -e rather than -d. Always returns 0 with the repo
# root on stdout (or empty stdout when not in a repo) - returning non-zero
# would trip `set -e` at the command-substitution call site.
#
# The loop always terminates and needs no endless-loop guard: every caller passes
# an absolute path ($PWD), and repeated `dirname` on an absolute path strictly
# shortens it until it reaches "/", where the loop stops. (`dirname` is only a
# fixed point at "/" and ".", and "." never arises from an absolute path.)
find_git_root() {
  search_dir="$1"
  while [ "$search_dir" != "/" ]; do
    if [ -e "$search_dir/.git" ]; then
      echo "$search_dir"
      return 0
    fi
    search_dir=$(dirname "$search_dir")
  done
}

# Determine mount directory based on #mount: directives or default behavior
MDIR=""

if [ -n "$MOUNT_KEYWORDS" ]; then
  # Process #mount: directives - FIRST found wins
  MOUNT_RESOLVED=0
  for keyword in $MOUNT_KEYWORDS; do
    case "$keyword" in
      home)
        if [ -d "$HOME" ]; then
          MDIR="$HOME"
          MOUNT_RESOLVED=1
          info "Mount directive: Using home directory ($HOME)"
          break
        else
          >&2 echo "WARNING: #mount: home - directory not found, trying next"
        fi
        ;;
      pwd)
        if [ -d "$PWD" ]; then
          MDIR="$PWD"
          MOUNT_RESOLVED=1
          info "Mount directive: Using current directory ($PWD)"
          break
        else
          >&2 echo "WARNING: #mount: pwd - directory not found, trying next"
        fi
        ;;
      .git)
        GIT_ROOT=$(find_git_root "$PWD")
        if [ -n "$GIT_ROOT" ]; then
          MDIR="$GIT_ROOT"
          MOUNT_RESOLVED=1
          info "Mount directive: Using git root directory ($GIT_ROOT)"
          break
        else
          >&2 echo "WARNING: #mount: .git - git repository not found, trying next"
        fi
        ;;
      *)
        >&2 echo "WARNING: #mount: unknown keyword '$keyword', ignoring"
        ;;
    esac
  done

  if [ "$MOUNT_RESOLVED" -eq 0 ]; then
    >&2 echo "ERROR: All #mount: directives failed to resolve a directory"
    exit 1
  fi
else
  # Default behavior (no #mount: directive): Try .git first, fall back to pwd
  # This provides secure-by-default behavior for git repositories
  GIT_ROOT=$(find_git_root "$PWD")
  if [ -n "$GIT_ROOT" ]; then
    MDIR="$GIT_ROOT"
  else
    MDIR="$PWD"
  fi
fi

# Optimized inspect: get architecture and context hash in one call
INSPECT_DATA=$("${ENGINE[@]}" inspect --format='{{.Architecture}}|{{index .Config.Labels "run-dockerfile.context-hash"}}' "${tag}" 2>/dev/null) || true

if [ -n "$INSPECT_DATA" ]; then
  IMGARCH=$(echo "$INSPECT_DATA" | cut -d'|' -f1)
  IMG_HASH=$(echo "$INSPECT_DATA" | cut -d'|' -f2)
else
  IMGARCH=""
  IMG_HASH=""
fi

# Compute a fingerprint of the build context for rebuild detection.
#
# Preferred path (GNU tar): hash a deterministic archive stream. Unlike a plain
# concatenation of file contents, this folds each entry's PATH, MODE and (for
# symlinks) TARGET into the hash, so a rename or chmod that changes the built
# image triggers a rebuild. mtime and owner are normalized so unrelated metadata
# churn does not. .git and editor swap files are excluded (never part of the image).
#
# The hash stays deliberately conservative: it does NOT parse .dockerignore, so it
# may rebuild more often than Docker strictly requires (safe - see the design note
# in CLAUDE.md). On hosts without GNU tar (e.g. stock macOS) it falls back to a
# deterministic metadata manifest that still includes PATH, MODE and symlink TARGET.
host_file_mode() {
  if stat -c '%a' "$1" >/dev/null 2>&1; then
    stat -c '%a' "$1"
  else
    stat -f '%Lp' "$1"
  fi
}

compute_context_hash_fallback() {
  _cch_dir=$1
  find "$_cch_dir" \( -path '*/.git' -o -path '*/.git/*' -o -name '*.swp' \) -prune -o -print 2>/dev/null \
    | sort | while IFS= read -r _cch_path; do
      _cch_rel=${_cch_path#"$_cch_dir"/}
      if [ "$_cch_path" = "$_cch_dir" ]; then
        _cch_rel=.
      fi
      _cch_mode=$(host_file_mode "$_cch_path")

      if [ -L "$_cch_path" ]; then
        printf 'L\t%s\t%s\t%s\n' "$_cch_mode" "$_cch_rel" "$(readlink "$_cch_path")"
      elif [ -d "$_cch_path" ]; then
        printf 'D\t%s\t%s\n' "$_cch_mode" "$_cch_rel"
      elif [ -f "$_cch_path" ]; then
        _cch_file_hash=$(host_sha256 < "$_cch_path")
        printf 'F\t%s\t%s\t%s\n' "$_cch_mode" "$_cch_rel" "$_cch_file_hash"
      fi
    done | host_sha256
}

compute_context_hash() {
  _cch_dir=$1
  _cch_tar=$(host_tar)
  if "$_cch_tar" --sort=name --version >/dev/null 2>&1; then
    "$_cch_tar" --sort=name --mtime='UTC 1970-01-01' --owner=0 --group=0 --numeric-owner \
        --exclude='*/.git' --exclude='*/.git/*' --exclude='*.swp' \
        -cf - -C "$_cch_dir" . 2>/dev/null | host_sha256
  else
    compute_context_hash_fallback "$_cch_dir"
  fi
}

# Calculate current context hash for change detection
CONTEXT_HASH=""
NEED_REBUILD=0

if [ -d "$dir" ]; then
  CONTEXT_HASH=$(compute_context_hash "$dir")
fi

# Check if rebuild is needed
if [ x"${IMGARCH}" = x"" ]; then
  >&2 echo "Docker image ${tag} not found, rebuilding..."
  NEED_REBUILD=1
elif [ -n "$CONTEXT_HASH" ] && [ "$IMG_HASH" != "$CONTEXT_HASH" ]; then
  if [ -z "$IMG_HASH" ]; then
    # Image exists without hash label - only rebuild if Dockerfile exists
    if [ -f "$dir/Dockerfile" ]; then
      >&2 echo "Image ${tag} exists but lacks hash label, rebuilding to enable change detection..."
      NEED_REBUILD=1
    else
      >&2 echo "Image ${tag} exists (no Dockerfile found, skipping hash check)"
      NEED_REBUILD=0
    fi
  else
    OLD_SHORT_HASH=$(echo "$IMG_HASH" | cut -c1-12)
    NEW_SHORT_HASH=$(echo "$CONTEXT_HASH" | cut -c1-12)
    >&2 echo "Context changes detected (${OLD_SHORT_HASH} → ${NEW_SHORT_HASH}), rebuilding image ${tag}..."
    NEED_REBUILD=1
  fi
fi

if [ "$NEED_REBUILD" -eq 1 ]; then
  # Image needs rebuild

  # Parse platform tag from Dockerfile
  BUILD_PLATFORM=""
  HTTP_SERVER_PIDS=""
  HTTP_PORT_FILES=""
  HTTP_SERVER_SCRIPT=""
  BUILD_ARGS=()
  BUILD_CONTEXT_ARGS=()

  if [ -f "$dir/Dockerfile" ]; then
    PLATFORM_LINE=$(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*platform:[[:space:]]*' | head -n 1)
    if [ -n "$PLATFORM_LINE" ]; then
      BUILD_PLATFORM=$(echo "$PLATFORM_LINE" | sed -E 's/^#[[:space:]]*platform:[[:space:]]*([^[:space:]]+).*/\1/')
      >&2 echo "Found platform tag in Dockerfile: ${BUILD_PLATFORM}"
    fi

    # Always use BuildKit - it is the modern Docker build path (the engine default
    # since Docker 23.0) and is required for `RUN --mount`, cache mounts, build
    # secrets, and named contexts. run-dockerfile assumes BuildKit is present and
    # does not support the legacy builder, so force it on unconditionally.
    export DOCKER_BUILDKIT=1
    info "Using BuildKit"

    # Parse #context: directives into BuildKit named contexts. Values are data:
    # split only on the first '=', trim outer whitespace, never shell-evaluate.
    while IFS= read -r context_line; do
      CONTEXT_SPEC=$(printf '%s' "$context_line" | sed -E 's/^#[[:space:]]*context:[[:space:]]*//')
      CONTEXT_NAME=$(trim_space "${CONTEXT_SPEC%%=*}")
      if [ "$CONTEXT_SPEC" = "${CONTEXT_SPEC#*=}" ]; then
        CONTEXT_VALUE=""
      else
        CONTEXT_VALUE=$(trim_space "${CONTEXT_SPEC#*=}")
      fi

      if [[ ! "$CONTEXT_NAME" =~ ^[a-z_][a-z0-9_.-]*$ ]]; then
        >&2 echo "ERROR: invalid #context: name '$CONTEXT_NAME' (expected [a-z_][a-z0-9_.-]*)"
        exit 1
      fi

      RESOLVED_CONTEXT_VALUE=$(resolve_build_context_value "$CONTEXT_VALUE")
      if build_context_value_is_local "$CONTEXT_VALUE" && [ ! -e "$RESOLVED_CONTEXT_VALUE" ]; then
        >&2 echo "ERROR: #context: local path does not exist for ${CONTEXT_NAME}: $RESOLVED_CONTEXT_VALUE"
        exit 1
      fi

      BUILD_CONTEXT_ARGS+=(--build-context "${CONTEXT_NAME}=${RESOLVED_CONTEXT_VALUE}")
    done < <(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*context:[[:space:]]*' || true)

    # Cleanup for HTTP servers, their per-server port files, and the shared
    # server script. Defined (and the trap armed) before any server starts so
    # an early exit mid-setup still tears everything down. Safe to call when
    # nothing was started (all variables default to empty).
    cleanup_http_servers() {
      if [ -n "$HTTP_SERVER_PIDS" ]; then
        >&2 echo "Stopping HTTP servers..."
        for pid in $HTTP_SERVER_PIDS; do
          kill $pid 2>/dev/null || true
        done
      fi
      for _pf in $HTTP_PORT_FILES; do
        rm -f "$_pf"
      done
      # Use an `if` (not `&&`) so an empty script path does not make this
      # function return non-zero - it is called directly under `set -e`.
      if [ -n "$HTTP_SERVER_SCRIPT" ]; then
        rm -f "$HTTP_SERVER_SCRIPT"
      fi
    }
    trap cleanup_http_servers EXIT INT TERM

    # Parse http.static directives and start one HTTP server per directive.
    HTTP_STATIC_LINES=$(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*http\.static:[[:space:]]*' || true)
    if [ -n "$HTTP_STATIC_LINES" ]; then
      # The server script is identical for every directive, so create it once
      # and reuse it; cleanup removes it. (A previous per-iteration mktemp
      # leaked, because the cleanup glob never matched the mktemp name.)
      HTTP_SERVER_SCRIPT=$(mktemp)
      cat > "$HTTP_SERVER_SCRIPT" <<'PYEOF'
import http.server
import socketserver
import sys
import os
import urllib.parse

serve_dir = sys.argv[1]
port_file = sys.argv[2]
token = sys.argv[3]

class TokenHandler(http.server.SimpleHTTPRequestHandler):
    def translate_path(self, path):
        parsed = urllib.parse.urlsplit(path)
        request_path = parsed.path
        token_prefix = "/" + token
        if request_path == token_prefix:
            stripped_path = "/"
        elif request_path.startswith(token_prefix + "/"):
            stripped_path = request_path[len(token_prefix):]
        else:
            return None

        rebuilt = urllib.parse.urlunsplit(("", "", stripped_path, parsed.query, parsed.fragment))
        return super().translate_path(rebuilt)

    def send_head(self):
        if self.translate_path(self.path) is None:
            self.send_error(404, "File not found")
            return None
        return super().send_head()

os.chdir(serve_dir)
with socketserver.TCPServer(("", 0), TokenHandler) as httpd:
    port = httpd.server_address[1]
    with open(port_file, 'w') as f:
        f.write(str(port))
    httpd.serve_forever()
PYEOF

      HTTP_SERVER_INDEX=0
      while IFS= read -r http_line; do
        # Parse: #http.static: KEY=/path/to/dir
        HTTP_SPEC=$(echo "$http_line" | sed -E 's/^#[[:space:]]*http\.static:[[:space:]]*//')
        HTTP_KEY=$(echo "$HTTP_SPEC" | cut -d= -f1)
        HTTP_PATH=$(echo "$HTTP_SPEC" | cut -d= -f2-)

        # Resolve relative paths against Dockerfile directory
        case "$HTTP_PATH" in
          /*) ;;  # absolute path - use as-is
          *) HTTP_PATH="$dir/$HTTP_PATH" ;;  # relative path - resolve from Dockerfile dir
        esac

        if [ ! -d "$HTTP_PATH" ]; then
          >&2 echo "ERROR: http.static path does not exist: $HTTP_PATH"
          exit 1
        fi

        HTTP_TOKEN=$(od -An -N16 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')
        if [ "${#HTTP_TOKEN}" -ne 32 ]; then
          >&2 echo "ERROR: Failed to generate HTTP token for $HTTP_KEY"
          exit 1
        fi

        # Each server gets its OWN port file. A shared file let the next
        # directive read the previous server's (stale) port before this server
        # had written its own, mapping the wrong directory to its build-arg.
        HTTP_SERVER_INDEX=$((HTTP_SERVER_INDEX + 1))
        HTTP_PORT_FILE="/tmp/run-dockerfile-http-port-$$-${HTTP_SERVER_INDEX}.txt"
        rm -f "$HTTP_PORT_FILE"
        HTTP_PORT_FILES="$HTTP_PORT_FILES $HTTP_PORT_FILE"

        cd "$HTTP_PATH"
        python3 "$HTTP_SERVER_SCRIPT" "$HTTP_PATH" "$HTTP_PORT_FILE" "$HTTP_TOKEN" 2>/dev/null &
        SERVER_PID=$!
        HTTP_SERVER_PIDS="$HTTP_SERVER_PIDS $SERVER_PID"

        # Wait up to 30s for THIS server to publish its port (-s: file exists
        # and is non-empty, so we never read a half-written port).
        SERVER_PORT=""
        for ((i = 1; i <= 60; i++)); do
          if [ -s "$HTTP_PORT_FILE" ]; then
            SERVER_PORT=$(cat "$HTTP_PORT_FILE")
            break
          fi
          sleep 0.5
        done

        if [ -z "$SERVER_PORT" ]; then
          # The EXIT trap (armed above) stops servers and removes temp files.
          >&2 echo "ERROR: Failed to start HTTP server for $HTTP_KEY"
          exit 1
        fi

        # Determine an address the build container can use to reach this HTTP
        # server on the host. The strategy is engine- and OS-specific because
        # each exposes host networking to containers differently.
        if [ "$ENGINE_KIND" = podman ]; then
          # Podman injects host.containers.internal into build containers (it
          # resolves to the host). Podman build containers are not on the
          # docker0 bridge, so the docker0 gateway IP used for Docker below is
          # unreachable. (`--add-host=...:host-gateway` is not used: Buildah
          # 1.28 rejects the host-gateway keyword.)
          HOST_IP="host.containers.internal"
        else
          case "$(uname -s)" in
            Darwin)
              # Docker Desktop on macOS injects host.docker.internal into the
              # container's resolver, pointing at the host. The `ip` command is
              # not available on macOS, so the Linux probes below would fail.
              HOST_IP="host.docker.internal"
              ;;
            *)
              # On Linux, use the Docker bridge gateway IP instead of
              # host.docker.internal (the latter is not injected by default).
              HOST_IP=$(ip route | awk '/docker0/ {print $9}' | head -n1)
              if [ -z "$HOST_IP" ]; then
                # Fallback to getting the default route IP
                HOST_IP=$(ip route get 1 | awk '{print $7;exit}')
              fi
              ;;
          esac
        fi
        SERVER_URL="http://${HOST_IP}:${SERVER_PORT}/${HTTP_TOKEN}"
        BUILD_ARGS+=(--build-arg "HTTP_${HTTP_KEY}=${SERVER_URL}")

        >&2 echo "Started HTTP server for ${HTTP_KEY}: ${SERVER_URL} (PID: ${SERVER_PID})"
        cd - >/dev/null
      done <<EOF
$HTTP_STATIC_LINES
EOF
    fi

    # Build docker image with collected options. Assembled as an array and
    # invoked directly (no eval), so paths/values are passed verbatim.
    BUILD_CMD=("${ENGINE[@]}" build -t "$tag" "${PROGRESS_ARGS[@]}")
    if [ -n "$BUILD_PLATFORM" ]; then
      # Normalize to OS/arch form - see comment near PLATFORM_ARG below.
      # `# platform: arm64` is accepted with the legacy image store but
      # fails as `--platform=arm64` against containerd-backed stores
      # (Docker Desktop), which need `linux/arm64`.
      case "$BUILD_PLATFORM" in
        */*) BUILD_CMD+=(--platform="${BUILD_PLATFORM}") ;;
        *)   BUILD_CMD+=(--platform="linux/${BUILD_PLATFORM}") ;;
      esac
    fi
    BUILD_CMD+=("${BUILD_CONTEXT_ARGS[@]}" "${BUILD_ARGS[@]}")
    # Add context hash label for change detection
    if [ -n "$CONTEXT_HASH" ]; then
      BUILD_CMD+=(--label "run-dockerfile.context-hash=${CONTEXT_HASH}")
    fi
    BUILD_CMD+=("$dir")

    >&2 echo "Running: ${BUILD_CMD[*]}"
    # `set -e` plus the armed EXIT/INT/TERM trap handle a failed build: a non-zero
    # build exits here and the trap tears down the HTTP servers. On success we
    # clean up explicitly and disarm the trap before continuing.
    # Build output goes to stderr: Podman prints build progress and the image id
    # to stdout, which would otherwise contaminate `$(./run cmd)` output on a
    # build-triggering invocation. (Docker/BuildKit already writes to stderr.)
    "${BUILD_CMD[@]}" >&2
    cleanup_http_servers
    trap - EXIT INT TERM
  else
    "${ENGINE[@]}" build -t "$tag" "${PROGRESS_ARGS[@]}" "$dir" >&2
  fi

  # Update architecture after build (reuse optimized inspect format)
  INSPECT_DATA=$("${ENGINE[@]}" inspect --format='{{.Architecture}}|{{index .Config.Labels "run-dockerfile.context-hash"}}' "${tag}" 2>/dev/null) || true
  if [ -n "$INSPECT_DATA" ]; then
    IMGARCH=$(echo "$INSPECT_DATA" | cut -d'|' -f1)
  fi
fi

# Bake the in-container entry script into the image at /bin/run-dockerfile-user-command
# instead of bind-mounting it. A read-only bind mount would add a read-only real-fs
# entry to /proc/mounts, which breaks tools that enumerate mounts for a writability
# check (e.g. RPM-based rootfs builds). The baked copy is a root-owned 0755 file the
# unprivileged user cannot overwrite, and the host scripts are never exposed.
#
# Thin image "${tag}.user-command" built FROM the base; rebuilt only when the base
# image id or the entry-script content changes (run-dockerfile.user-command-hash
# label), so the common unchanged path costs one extra `docker inspect` and no build.
#
# Locate the sibling entry script next to the REAL build-and-run: $0 is the `run`
# symlink (real_self deliberately keeps it unresolved, for dir/tag), so follow its
# symlinks here to find where build-and-run actually lives.
_self_resolved=$0
case $_self_resolved in /*) ;; *) _self_resolved=$PWD/$_self_resolved ;; esac
while [ -L "$_self_resolved" ]; do
  _self_link=$(readlink "$_self_resolved")
  case $_self_link in
    /*) _self_resolved=$_self_link ;;
    *)  _self_resolved=$(dirname "$_self_resolved")/$_self_link ;;
  esac
done
USER_COMMAND_SRC="$(dirname "$(host_realpath_no_symlinks "$_self_resolved")")/run-dockerfile-user-command"
if [ ! -f "$USER_COMMAND_SRC" ]; then
  >&2 echo "ERROR: in-container entry script not found next to build-and-run: $USER_COMMAND_SRC"
  exit 1
fi

run_tag="${tag}.user-command"
SCRIPT_HASH=$(host_sha256 < "$USER_COMMAND_SRC")
BASE_ID=$("${ENGINE[@]}" inspect --format='{{.Id}}' "$tag" 2>/dev/null) || true
if [ -z "$BASE_ID" ]; then
  >&2 echo "ERROR: base image ${tag} not found; cannot bake /bin/run-dockerfile-user-command into it."
  exit 1
fi
USER_COMMAND_HASH=$(printf '%s|%s' "$BASE_ID" "$SCRIPT_HASH" | host_sha256)

RUN_INSPECT=$("${ENGINE[@]}" inspect --format='{{index .Config.Labels "run-dockerfile.user-command-hash"}}' "$run_tag" 2>/dev/null) || true
if [ "$RUN_INSPECT" != "$USER_COMMAND_HASH" ]; then
  >&2 echo "Baking /bin/run-dockerfile-user-command into ${run_tag}..."
  # COPY --chmod and the deterministic layer both rely on BuildKit, which this tool
  # always enables. Force it on for the case where the base image already existed and
  # the main build above (which exports it) was skipped.
  export DOCKER_BUILDKIT=1
  RUN_BUILD_CTX=$(mktemp -d)
  cp "$USER_COMMAND_SRC" "$RUN_BUILD_CTX/run-dockerfile-user-command"
  {
    printf 'FROM %s\n' "$tag"
    printf 'COPY --chmod=0755 run-dockerfile-user-command /bin/run-dockerfile-user-command\n'
  } > "$RUN_BUILD_CTX/Dockerfile"
  DERIVE_CMD=("${ENGINE[@]}" build -t "$run_tag" "${PROGRESS_ARGS[@]}")
  # Match the base image architecture so cross-platform images bake correctly.
  if [ -n "$IMGARCH" ]; then
    case "$IMGARCH" in
      */*) DERIVE_CMD+=(--platform="${IMGARCH}") ;;
      *)   DERIVE_CMD+=(--platform="linux/${IMGARCH}") ;;
    esac
  fi
  DERIVE_CMD+=(--label "run-dockerfile.user-command-hash=${USER_COMMAND_HASH}" "$RUN_BUILD_CTX")
  # Build output to stderr (see the base build above): keep stdout clean for the
  # user command.
  if ! "${DERIVE_CMD[@]}" >&2; then
    rm -rf "$RUN_BUILD_CTX"
    >&2 echo "ERROR: failed to bake /bin/run-dockerfile-user-command into ${run_tag}."
    exit 1
  fi
  rm -rf "$RUN_BUILD_CTX"
fi

# Check if stdin is a TTY using POSIX test
TFLAG=()
if [ -t 0 ]; then
  TFLAG=(-t)
fi

# Set platform argument only if IMGARCH is not empty.
# `docker inspect ... {{.Architecture}}` returns a bare arch (e.g. "arm64").
# That works with the legacy image store, but containerd-backed stores (used
# by Docker Desktop) match images by full "os/arch" - a bare "arm64" misses
# the manifest's "linux/arm64" entry and `docker run` then tries to pull
# from a registry. Normalize to "linux/<arch>" when no slash is present.
PLATFORM_ARG=()
if [ -n "$IMGARCH" ]; then
  case "$IMGARCH" in
    */*) PLATFORM_ARG=(--platform "${IMGARCH}") ;;
    *)   PLATFORM_ARG=(--platform "linux/${IMGARCH}") ;;
  esac
fi

# Cleanup function for the temporary #copy.home: tar file. Defined here - before
# the archive is created - so the trap can be armed the instant the file exists,
# leaving no window in which a later failure (e.g. a #usermount: mkdir) could
# leak the archive in /tmp.
cleanup_copy_home() {
  if [ -n "$COPY_HOME_TAR" ] && [ -f "$COPY_HOME_TAR" ]; then
    rm -f "$COPY_HOME_TAR"
  fi
}

# Handle #copy.home: files - create tar archive
COPY_HOME_VARG=()
COPY_HOME_TAR=""
if [ ${#COPY_HOME_FILES[@]} -gt 0 ]; then
  COPY_HOME_TAR="/tmp/run-dockerfile-home-files-$$.tar.gz"
  trap cleanup_copy_home EXIT INT TERM
  cd "$HOME"

  # Try to create tar, check for missing files. The file list is a quoted array,
  # so filenames containing spaces are passed to tar as single arguments.
  if "$(host_tar)" czf "$COPY_HOME_TAR" "${COPY_HOME_FILES[@]}" 2>/dev/null; then
    COPY_HOME_VARG=(-v "$COPY_HOME_TAR:/tmp/home-files.tar.gz:ro")
    info "Collected home files for container: ${COPY_HOME_FILES[*]}"
  else
    # Tar failed, list missing files
    >&2 echo "ERROR: Failed to collect files from \$HOME. Missing files:"
    for f in "${COPY_HOME_FILES[@]}"; do
      if [ ! -e "$HOME/$f" ]; then
        >&2 echo "  $HOME/$f"
      fi
    done
    exit 1
  fi
  cd - >/dev/null
fi

# Process #usermount: directives - expand env vars, create dirs, build volume args
USERMOUNT_VARGS=()
if [ ${#USERMOUNT_PATHS[@]} -gt 0 ]; then
  for path in "${USERMOUNT_PATHS[@]}"; do
    # Expand environment-variable references in path safely (no shell eval)
    expanded_path=$(expand_usermount_path "$path")
    if [ ! -d "$expanded_path" ]; then
      mkdir -p "$expanded_path"
      >&2 echo "Created directory: $expanded_path"
    fi
    USERMOUNT_VARGS+=(-v "$expanded_path:$expanded_path")
  done
  if [ ${#USERMOUNT_VARGS[@]} -gt 0 ]; then
    info "Mounting user directories: ${USERMOUNT_VARGS[*]}"
  fi
fi

# Parse #option: directives for additional docker run options
DOCKER_OPTIONS=()
OPTION_ENV_VARS=""
if [ -f "$dir/Dockerfile" ]; then
  OPTION_LINES=$(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*option:[[:space:]]*' || true)
  if [ -n "$OPTION_LINES" ]; then
    # Each #option: directive is one docker-run option. Split only once: the
    # option token itself, then the entire remaining text as that option's value.
    # This keeps values containing spaces/globs literal without shell evaluation.
    while IFS= read -r _opt_line; do
      _opt_value=$(printf '%s' "$_opt_line" | sed -E 's/^#[[:space:]]*option:[[:space:]]*//; s/[[:space:]]+$//')
      [ -n "$_opt_value" ] || continue

      _opt_name=${_opt_value%%[[:space:]]*}
      if [ "$_opt_name" = "$_opt_value" ]; then
        DOCKER_OPTIONS+=("$_opt_name")
      else
        _opt_arg=$(trim_space "${_opt_value#"$_opt_name"}")
        case "$_opt_name" in
          --privileged|--read-only)
            >&2 echo "ERROR: #option: ${_opt_name} does not take a value; use one docker option per #option: line"
            exit 1
            ;;
        esac
        DOCKER_OPTIONS+=("$_opt_name" "$_opt_arg")
      fi
    done <<EOF
$OPTION_LINES
EOF
    # Extract env var names from -e/--env options for ENV preservation. Walk the
    # parsed token array (not the raw text) so we only match genuine option
    # tokens - never an "-e" substring inside a word like "--entrypoint" - and so
    # the inherit form `-e NAME` (no '=') is captured just like on the command
    # line. Mirrors the -e / --env / --env= forms the command-line parser accepts.
    _opt_n=${#DOCKER_OPTIONS[@]}
    _opt_i=0
    while [ "$_opt_i" -lt "$_opt_n" ]; do
      _opt_name=""
      case "${DOCKER_OPTIONS[$_opt_i]}" in
        -e|--env)
          _opt_i=$((_opt_i + 1))
          _opt_name=${DOCKER_OPTIONS[$_opt_i]%%=*}
          ;;
        --env=*)
          _opt_name=${DOCKER_OPTIONS[$_opt_i]#--env=}
          _opt_name=${_opt_name%%=*}
          ;;
      esac
      if [ -n "$_opt_name" ]; then
        OPTION_ENV_VARS="${OPTION_ENV_VARS:+$OPTION_ENV_VARS,}$_opt_name"
      fi
      _opt_i=$((_opt_i + 1))
    done
  fi
fi

# Parse #sudo: directive for sudoers configuration
SUDO_MODE=""
SUDO_MODE_ARG=()
if [ -f "$dir/Dockerfile" ]; then
  SUDO_LINE=$(printf '%s\n' "$DIRECTIVE_STREAM" | grep -E '^#[[:space:]]*sudo:[[:space:]]*' | tail -1 || true)
  if [ -n "$SUDO_LINE" ]; then
    SUDO_MODE=$(echo "$SUDO_LINE" | sed -E 's/^#[[:space:]]*sudo:[[:space:]]*//' | tr -d ' ')
  fi
fi
if [ "$SUDO_MODE" = "all" ]; then
  SUDO_MODE_ARG=(-e DOCKER_SUDO_MODE=all)
fi

# Auto-preserve ENV vars from Dockerfile across su
# Extract ENV var names after the last FROM line
PRESERVE_ENV_ARG=()
ENV_VARS=""
if [ -f "$dir/Dockerfile" ]; then
  # Get line number of last FROM, then extract ENV var names after it.
  LAST_FROM=$(grep -n '^FROM' "$dir/Dockerfile" | tail -1 | cut -d: -f1)
  if [ -n "$LAST_FROM" ]; then
    # Handle both ENV forms, emitting EVERY name (not just the first):
    #   ENV k=v [k2=v2 ...]   -> one name per whitespace-separated key=value field
    #   ENV key value...      -> a single name (legacy form; value is the rest)
    # A '=' inside a value stays within its own field, so it is not mistaken for
    # another name. Quoted values containing whitespace are only best-effort and
    # line-continuations are not joined (see CLAUDE.md).
    ENV_VARS=$(tail -n +"$LAST_FROM" "$dir/Dockerfile" | awk '
      /^[[:space:]]*ENV[[:space:]]+/ {
        line = $0
        sub(/^[[:space:]]*ENV[[:space:]]+/, "", line)
        n = split(line, f, /[[:space:]]+/)
        if (index(line, "=") == 0) {
          if (f[1] ~ /^[A-Za-z_][A-Za-z0-9_]*$/) print f[1]
        } else {
          for (i = 1; i <= n; i++) {
            if (match(f[i], /^[A-Za-z_][A-Za-z0-9_]*=/)) {
              print substr(f[i], 1, RLENGTH - 1)
            }
          }
        }
      }
    ' | tr '\n' ',' | sed 's/,$//')
  fi
fi
# Combine Dockerfile ENV vars with command-line and #option: env vars
for extra_vars in "$CMDLINE_ENV_VARS" "$OPTION_ENV_VARS"; do
  if [ -n "$extra_vars" ]; then
    if [ -n "$ENV_VARS" ]; then
      ENV_VARS="$ENV_VARS,$extra_vars"
    else
      ENV_VARS="$extra_vars"
    fi
  fi
done
if [ -n "$ENV_VARS" ]; then
  PRESERVE_ENV_ARG=(-e "DOCKER_PRESERVE_ENV=$ENV_VARS")
fi

# Expand inherit-form env options ("-e NAME" / "--env NAME" / "--env=NAME" with no
# "=value") to "NAME=value" using THIS process's environment, then store the result
# in EXPANDED_ENV_ARGS. The engine otherwise reads the value from its own
# environment, which `sudo podman` cannot see: sudo resets the environment, so a
# bare "-e NAME" would arrive empty. Doing the lookup host-side fixes that and is
# behaviour-identical for Docker (an inherit "-e NAME" with NAME set equals
# "-e NAME=value"). A NAME that is unset on the host is left as the bare inherit
# form, so its name is still added to the preserve list and the container defines
# it empty (the documented #option: -e behaviour; regression-tested by tests/0037).
expand_env_inherit() {
  EXPANDED_ENV_ARGS=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -e|--env)
        if [ "$#" -ge 2 ]; then
          _ee_flag=$1; _ee_val=$2; shift 2
          case "$_ee_val" in
            *=*) EXPANDED_ENV_ARGS+=("$_ee_flag" "$_ee_val") ;;
            *)
              if [[ "$_ee_val" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] && [ -n "${!_ee_val+x}" ]; then
                EXPANDED_ENV_ARGS+=("$_ee_flag" "$_ee_val=${!_ee_val}")
              else
                EXPANDED_ENV_ARGS+=("$_ee_flag" "$_ee_val")
              fi
              ;;
          esac
        else
          EXPANDED_ENV_ARGS+=("$1"); shift
        fi
        ;;
      --env=*)
        _ee_val=${1#--env=}
        case "$_ee_val" in
          *=*) EXPANDED_ENV_ARGS+=("$1") ;;
          *)
            if [[ "$_ee_val" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] && [ -n "${!_ee_val+x}" ]; then
              EXPANDED_ENV_ARGS+=("--env=$_ee_val=${!_ee_val}")
            else
              EXPANDED_ENV_ARGS+=("$1")
            fi
            ;;
        esac
        shift
        ;;
      *)
        EXPANDED_ENV_ARGS+=("$1"); shift
        ;;
    esac
  done
}
expand_env_inherit "${CMDLINE_ENV_ARGS[@]}"
CMDLINE_ENV_ARGS=("${EXPANDED_ENV_ARGS[@]}")
expand_env_inherit "${DOCKER_OPTIONS[@]}"
DOCKER_OPTIONS=("${EXPANDED_ENV_ARGS[@]}")

# Identify the host user from `id`, not the $USER env var: `id` is authoritative
# and always present, whereas $USER can be empty (cron, CI, `env -i`) or stale
# (e.g. after `su -m`), which would create a mismatched or malformed container
# user. The UID, GID and group name already come from `id` for the same reason.
DOCKER_RUN_CMD=("${ENGINE[@]}" run --rm -i "${TFLAG[@]}" \
  "${ROOTLESS_RUN_ARGS[@]}" \
  -v "$MDIR:$MDIR" \
  "${COPY_HOME_VARG[@]}" \
  "${USERMOUNT_VARGS[@]}" \
  -w "$PWD" \
  --entrypoint /bin/sh \
  "${PLATFORM_ARG[@]}" \
  "${PRESERVE_ENV_ARG[@]}" \
  "${SUDO_MODE_ARG[@]}" \
  "${CMDLINE_ENV_ARGS[@]}" \
  "${CMDLINE_DOCKER_ARGS[@]}" \
  "${DOCKER_OPTIONS[@]}" \
  "$run_tag" \
  /bin/run-dockerfile-user-command "$(id -un)" "$(id -u)" "$(id -g)" "$(id -gn)" "$HOME" "$@")

# All accumulated docker arguments are bash arrays expanded as "${arr[@]}", and
# every path/value is quoted, so spaces and glob characters are passed verbatim.
# "$@" (not $*) preserves the user command's argument boundaries. When a
# #copy.home: tarball exists, do not exec: the shell must survive long enough to
# remove the host-side temp archive after docker exits.
if [ -n "$COPY_HOME_TAR" ]; then
  set +e
  "${DOCKER_RUN_CMD[@]}"
  DOCKER_RUN_RESULT=$?
  set -e
  cleanup_copy_home
  trap - EXIT INT TERM
  exit "$DOCKER_RUN_RESULT"
fi

exec "${DOCKER_RUN_CMD[@]}"
